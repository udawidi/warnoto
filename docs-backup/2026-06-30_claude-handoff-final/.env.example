# Salin file ini jadi ".env" lalu isi value asli (.env tidak ikut ke git)

VITE_GROQ_API_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_COHERE_API_KEY=

# Supabase Edge Function / WhatsApp Cloud API
# Set sebagai Supabase secrets, bukan Vite env frontend:
# npx supabase secrets set WHATSAPP_VERIFY_TOKEN=...
# npx supabase secrets set WHATSAPP_ACCESS_TOKEN=...
# npx supabase secrets set WHATSAPP_PHONE_NUMBER_ID=...
# npx supabase secrets set GROQ_API_KEY=...
# npx supabase secrets set COHERE_API_KEY=...
